classDiagram
    class Task {
        +str name
        +int duration
        +str priority
        +bool completed
        +mark_complete()
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task)
        +list_tasks()
    }

    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet)
        +get_all_tasks()
    }

    class Scheduler {
        +sort_tasks(tasks)
        +generate_plan(owner)
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler ..> Owner : reads